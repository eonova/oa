<view class="page">
  <view class="header">
    <view class="eyebrow">PC 通知</view>
    <view class="title">待我审核</view>
  </view>

  <block wx:if="{{items.length}}">
    <view wx:for="{{items}}" wx:key="id" class="card">
      <view class="card-title">{{item.title}}</view>
      <view class="muted">{{item.message}}</view>
      <view class="muted">创建时间：{{item.createdAt}}</view>
      <view class="badge">{{item.statusText}}</view>
      <view class="actions">
        <button class="button secondary" data-id="{{item.id}}" bindtap="markRead">标记已读</button>
        <button class="button" data-task-id="{{item.reviewTaskId}}" bindtap="openReview">去审核</button>
      </view>
    </view>
  </block>

  <view wx:else class="empty">暂无待办通知</view>
</view>
