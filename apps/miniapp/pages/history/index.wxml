<view class="page">
  <view class="header">
    <view class="eyebrow">手机审核</view>
    <view class="title">处理历史</view>
  </view>

  <block wx:if="{{items.length}}">
    <view wx:for="{{items}}" wx:key="id" class="card">
      <view class="card-title">{{item.record.title}}</view>
      <view class="muted">处理时间：{{item.handledAt}}</view>
      <view class="muted">审核意见：{{item.comment}}</view>
      <view class="badge">{{item.statusText}}</view>
    </view>
  </block>

  <view wx:else class="empty">暂无审核历史</view>
</view>
