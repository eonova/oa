<view class="page">
  <view class="header">
    <view class="eyebrow">审核详情</view>
    <view class="title">{{task.record.title}}</view>
  </view>

  <view wx:if="{{task}}" class="card">
    <view class="card-title">{{task.record.category}}</view>
    <view class="muted">部门：{{task.record.department}}</view>
    <view class="muted">负责人：{{task.record.owner}}</view>
    <view class="muted">截止日期：{{task.record.dueDate}}</view>
    <view class="badge">{{task.statusText}}</view>

    <textarea class="textarea" placeholder="填写审核意见" value="{{comment}}" bindinput="onCommentInput" />

    <view class="actions">
      <button class="button danger" bindtap="reject">驳回</button>
      <button class="button" bindtap="approve">通过</button>
    </view>
  </view>
</view>
