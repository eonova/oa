page {
  min-height: 100vh;
  background: #eef3f0;
  color: #1d2524;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  padding: 28rpx;
}

.header {
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #6a7673;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #d9e1dd;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(29, 37, 36, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: 800;
}

.muted {
  color: #6a7673;
  font-size: 26rpx;
  line-height: 1.6;
}

.badge {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e6f4ef;
  color: #176b57;
  font-size: 24rpx;
  font-weight: 800;
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.button {
  flex: 1;
  min-height: 76rpx;
  border-radius: 12rpx;
  background: #1f8a70;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 76rpx;
}

.button.secondary {
  border: 1rpx solid #b8ded1;
  background: #e6f4ef;
  color: #176b57;
}

.button.danger {
  background: #c14444;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #d9e1dd;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
  font-size: 28rpx;
}

.empty {
  padding: 80rpx 20rpx;
  color: #6a7673;
  text-align: center;
}
